# ============================================================
# AI Coding Agent — Environment Variables Template
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# --- LLM Providers (at least one required) ---

# Anthropic Claude (recommended)
# Get your key: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI (optional fallback)
# Get your key: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Ollama (no key needed — runs locally)
# Start Ollama: `ollama serve`
OLLAMA_BASE_URL=http://localhost:11434

# --- Tool: Web Search ---

# Tavily (recommended for agent web search)
# Get your key: https://tavily.com/
TAVILY_API_KEY=tvly-...

# SerpAPI (alternative)
SERPAPI_KEY=

# --- Agent Behaviour ---

# Default LLM provider: anthropic | openai | ollama
AGENT_LLM_PROVIDER=anthropic

# Default model name
AGENT_MODEL=claude-sonnet-4-5

# Max reasoning steps before the agent stops
AGENT_MAX_STEPS=30

# Timeout per tool call (seconds)
AGENT_TOOL_TIMEOUT=30

# --- Sandbox ---

# Docker sandbox image tag
SANDBOX_IMAGE=ai-coding-agent-sandbox:latest

# Max CPU cores for sandbox container
SANDBOX_CPU_LIMIT=1.0

# Max RAM for sandbox container
SANDBOX_MEMORY_LIMIT=512m

# --- Observability (optional) ---

# OpenTelemetry collector endpoint
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
